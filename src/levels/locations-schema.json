              "slot": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9
              },
              "mode": {
                "type": "string",
                "const": "play"
              },
              "playerPos": {
                "type": "array",
                "items": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "number"
                  },
                  {
                    "type": "number"
                  }
                ]
              },
              "cameraAngles": {
                "type": "object",
                "properties": {
                  "phi": {
                    "type": "number"
                  },
                  "theta": {
                    "type": "number"
                  }
                },
                "required": [
                  "phi",
                  "theta"
                ],
