              }
            },
            "required": [
              "slot",
              "mode",
              "playerPos",
              "cameraAngles"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "slot": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9
              },
              "mode": {
                "type": "string",
                "const": "edit"
              },
              "cameraPos": {
                "type": "array",
                "items": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "number"
                  },
                  {
                    "type": "number"
                  }
                ]
              },
              "orbitTarget": {
                "type": "array",
                "items": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "number"
                  },
                  {
                    "type": "number"
                  }
                ]
              }
            },
            "required": [
              "slot",
              "mode",
              "cameraPos",
              "orbitTarget"
            ],
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "additionalProperties": false,
  "title": "LocationsFile",
  "$id": "https://ameo.design/schemas/level-locations.json"
}
