{
  "$schema": "../materials-schema.json",
  "textures": {
    "shiny_patchwork_stone_diffuse": {
      "url": "https://geotoy.b-cdn.net/textures/1/20165df3-fe44-49dd-84a7-9e8112e0d94b.avif",
      "colorSpace": "srgb"
    },
    "shiny_patchwork_stone_normal": {
      "url": "https://geotoy.b-cdn.net/textures/1/74ac0b42-56d5-4999-ab1d-397e8fef2173.avif"
    }
  },
  "materials": {
    "geotoy_slate": {
      "type": "geotoyMaterial",
      "materialId": 7
    },
    "triangle_grid": {
      "type": "customShader",
      "extends": {
        "type": "library",
        "path": "procedural/triangle_grid"
      }
    },
    "chevron_strips_wide": {
      "type": "customShader",
      "extends": {
        "type": "library",
        "path": "procedural/chevron_strips"
      },
      "props": {
        "roughness": 0.3,
        "metalness": 0.6
      },
      "shaders": {
        "constants": {
          "CH_AMP": {
            "type": "float",
            "value": 2.4
          },
          "CH_WPITCH": {
            "type": "float",
            "value": 6.5
          },
          "CH_COLOR_A": {
            "type": "vec3",
            "value": [0.05, 0.06, 0.08]
          },
          "CH_COLOR_B": {
            "type": "vec3",
            "value": [0.62, 0.5, 0.16]
          }
        }
      }
    },
    "pit_grid_diamond": {
      "type": "customShader",
      "extends": {
        "type": "library",
        "path": "procedural/pit_grid"
      },
      "shaders": {
        "constants": {
          "PG_SHAPE": {
            "type": "int",
            "value": 1
          }
        }
      }
    },
    "pit_grid_triangle": {
      "type": "customShader",
      "extends": {
        "type": "library",
        "path": "procedural/pit_grid"
      },
      "shaders": {
        "constants": {
          "PG_SHAPE": {
            "type": "int",
            "value": 2
          }
        }
      }
    },
    "pit_grid_trapezoid": {
      "type": "customShader",
      "extends": {
        "type": "library",
        "path": "procedural/pit_grid"
      },
      "shaders": {
        "constants": {
          "PG_SHAPE": {
            "type": "int",
            "value": 3
          }
        }
      }
    },
    "pit_grid_stagger": {
      "type": "customShader",
      "extends": {
        "type": "library",
        "path": "procedural/pit_grid"
      },
      "shaders": {
        "constants": {
          "PG_STAGGER": {
            "type": "int",
            "value": 1
          }
        }
      }
    },
    "moulding_uv": {
      "type": "customShader",
      "extends": {
        "type": "library",
        "path": "procedural/moulding"
      },
      "shaders": {
        "constants": {
          "PAT_UV_MODE": {
            "type": "int",
            "value": 1
          },
          "PAT_UV_SCALE": {
            "type": "vec2",
            "value": [0.4, 3]
          }
        }
      }
    },
    "shape_strip_uv": {
      "type": "customShader",
      "extends": {
        "type": "library",
        "path": "procedural/shape_strip"
      },
      "shaders": {
        "constants": {
          "PAT_UV_MODE": {
            "type": "int",
            "value": 1
          },
          "PAT_UV_SCALE": {
            "type": "vec2",
            "value": [0.4, 3]
          },
          "SS_SHAPE": {
            "type": "int",
            "value": 1
          }
        }
      }
    },
    "bricks_red": {
      "type": "customShader",
      "extends": {
        "type": "library",
        "path": "procedural/bricks"
      },
      "shaders": {
        "constants": {
          "BR_CELL": {
            "type": "vec2",
            "value": [1.6, 0.55]
          },
          "BR_JOINT_HW": {
            "type": "float",
            "value": 0.035
          },
          "BR_BEVEL_W": {
            "type": "float",
            "value": 0.06
          },
          "BR_BLOCK_COLOR": {
            "type": "vec3",
            "value": [0.42, 0.16, 0.11]
          },
          "BR_MORTAR_COLOR": {
            "type": "vec3",
            "value": [0.55, 0.52, 0.46]
          },
          "BR_SOOT_AMT": {
            "type": "float",
            "value": 0.55
          },
          "BR_TINT_AMP": {
            "type": "float",
            "value": 0.16
          }
        }
      }
    },
    "tube_texture": {
      "type": "customShader",
      "props": {
        "color": "#aaaaaa",
        "roughness": 0.3,
        "metalness": 0.1,
        "uvScale": [0.1, 1],
        "map": "shiny_patchwork_stone_diffuse",
        "normalMap": "shiny_patchwork_stone_normal"
      },
      "options": {
        "useTriplanarMapping": false,
        "useGeneratedUVs": false
      }
    },
    "demo_local_base": {
      "type": "customShader",
      "props": {
        "color": "#c24d2c",
        "roughness": 0.6,
        "metalness": 0.1
      }
    },
    "demo_extends_local": {
      "type": "customShader",
      "extends": {
        "type": "local",
        "name": "demo_local_base"
      },
      "props": {
        "color": "#2c74c2",
        "metalness": 0.85
      }
    },
    "demo_extends_library": {
      "type": "customShader",
      "extends": {
        "type": "library",
        "path": "procedural/pit_grid"
      },
      "props": {
        "roughness": 0.25
      },
      "shaders": {
        "constants": {
          "PG_SHAPE": {
            "type": "int",
            "value": 2
          }
        }
      }
    },
    "demo_extends_geotoy": {
      "type": "customShader",
      "extends": {
        "type": "geotoy",
        "materialId": 7
      },
      "props": {
        "metalness": 0.9,
        "roughness": 0.2
      }
    },
    "corrugated_metal_rings": {
      "type": "customShader",
      "extends": {
        "type": "library",
        "path": "procedural/corrugated_metal"
      },
      "shaders": {
        "constants": {
          "PAT_UV_MODE": {
            "type": "int",
            "value": 1
          },
          "PAT_AXIS": {
            "type": "int",
            "value": 0
          },
          "PAT_UV_SCALE": {
            "type": "vec2",
            "value": [1, 7.7]
          }
        }
      }
    }
  }
}
