{
  "$schema": "../materials-schema.json",
  "materials": {
    "plain_strip_mat": {
      "type": "customShader",
      "props": {
        "color": "#6e8aa6",
        "roughness": 0.85,
        "metalness": 0.05
      },
      "externalVelocityGroundDampingFactor": [0.99, 0.99, 0.99]
    },
    "goal": {
      "type": "customShader",
      "props": {
        "color": "#03a800",
        "emissiveIntensity": 0.55,
        "roughness": 0.45,
        "metalness": 0.15
      },
      "externalVelocityGroundDampingFactor": [1, 1, 1]
    },
    "triangle_grid": {
      "type": "customShader",
      "props": {
        "color": "#2f7d7a",
        "roughness": 0.7,
        "metalness": 0.05
      },
      "options": {
        "useTriplanarMapping": false,
        "useGeneratedUVs": false,
        "pom": {
          "depth": 0.45,
          "steps": 16,
          "lodFadeStart": 15,
          "lodFadeRange": 60,
          "boundedSilhouette": true,
          "refinement": "binary",
          "refinementSteps": 3,
          "applyReliefNormal": true
        }
      },
      "shaders": {
        "commonShader": {
          "file": "triangleGrid.common.glsl"
        },
        "colorShader": {
          "file": "triangleGrid.color.glsl"
        },
        "lightAttenuationShader": {
          "file": "triangleGrid.attenuation.glsl"
        },
        "pomHeightShader": {
          "file": "triangleGrid.height.glsl"
        },
        "pomNormalShader": {
          "file": "triangleGrid.normal.glsl"
        }
      }
    },
    "grooved_plastic": {
      "type": "customShader",
      "props": {
        "color": "#5d5e60",
        "roughness": 0.6,
        "metalness": 0
      },
      "options": {
        "useTriplanarMapping": false,
        "useGeneratedUVs": false,
        "pom": {
          "depth": 0.07,
          "steps": 8,
          "lodFadeStart": 12,
          "lodFadeRange": 30,
          "refinement": "binary",
          "refinementSteps": 3,
          "applyReliefNormal": true
        }
      },
      "shaders": {
        "commonShader": {
          "file": "groovedPlastic.common.glsl"
        },
        "colorShader": {
          "file": "groovedPlastic.color.glsl"
        },
        "lightAttenuationShader": {
          "file": "groovedPlastic.attenuation.glsl"
        },
        "pomHeightShader": {
          "file": "groovedPlastic.height.glsl"
        },
        "pomNormalShader": {
          "file": "groovedPlastic.normal.glsl"
        }
      }
    },
    "panel_seams": {
      "type": "customShader",
      "props": {
        "color": "#5d5e60",
        "roughness": 0.6,
        "metalness": 0
      },
      "options": {
        "useTriplanarMapping": false,
        "useGeneratedUVs": false,
        "pom": {
          "depth": 0.05,
          "steps": 6,
          "lodFadeStart": 10,
          "lodFadeRange": 25,
          "refinement": "binary",
          "refinementSteps": 3,
          "applyReliefNormal": true
        }
      },
      "shaders": {
        "commonShader": {
          "file": "panelSeams.common.glsl"
        },
        "colorShader": {
          "file": "panelSeams.color.glsl"
        },
        "lightAttenuationShader": {
          "file": "panelSeams.attenuation.glsl"
        },
        "pomHeightShader": {
          "file": "panelSeams.height.glsl"
        },
        "pomNormalShader": {
          "file": "panelSeams.normal.glsl"
        }
      }
    },
    "superellipse_tiles": {
      "type": "customShader",
      "props": {
        "color": "#7d796f",
        "roughness": 0.5,
        "metalness": 0
      },
      "options": {
        "useTriplanarMapping": false,
        "useGeneratedUVs": false,
        "pom": {
          "depth": 0.16,
          "steps": 10,
          "lodFadeStart": 16,
          "lodFadeRange": 40,
          "refinement": "binary",
          "refinementSteps": 4,
          "applyReliefNormal": true
        }
      },
      "shaders": {
        "commonShader": {
          "file": "superellipseTiles.common.glsl"
        },
        "colorShader": {
          "file": "superellipseTiles.color.glsl"
        },
        "lightAttenuationShader": {
          "file": "superellipseTiles.attenuation.glsl"
        },
        "pomHeightShader": {
          "file": "superellipseTiles.height.glsl"
        },
        "pomNormalShader": {
          "file": "superellipseTiles.normal.glsl"
        }
      }
    },
    "grate_trench": {
      "type": "customShader",
      "props": {
        "color": "#5d5e60",
        "roughness": 0.6,
        "metalness": 0
      },
      "options": {
        "useTriplanarMapping": false,
        "useGeneratedUVs": false,
        "pom": {
          "depth": 0.12,
          "steps": 10,
          "lodFadeStart": 12,
          "lodFadeRange": 30,
          "refinement": "binary",
          "refinementSteps": 3,
          "applyReliefNormal": true
        }
      },
      "shaders": {
        "commonShader": {
          "file": "grateTrench.common.glsl"
        },
        "colorShader": {
          "file": "grateTrench.color.glsl"
        },
        "lightAttenuationShader": {
          "file": "grateTrench.attenuation.glsl"
        },
        "pomHeightShader": {
          "file": "grateTrench.height.glsl"
        },
        "pomNormalShader": {
          "file": "grateTrench.normal.glsl"
        }
      }
    }
  }
}
