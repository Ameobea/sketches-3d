{
  "$schema": "../../../library-material-schema.json",
  "material": {
    "type": "customShader",
    "props": {
      "color": "#5d5e60",
      "roughness": 0.6,
      "metalness": 0
    },
    "options": {
      "useTriplanarMapping": false,
      "useGeneratedUVs": false,
      "pom": {
        "tier": "projectedField",
        "intersect": "safeStep",
        "minFeatureWidth": 0.1,
        "depth": 0.05,
        "steps": 6,
        "lodFadeStart": 10,
        "lodFadeRange": 25,
        "refinement": "binary",
        "refinementSteps": 3,
        "applyReliefNormal": true
      }
    },
    "shaders": {
      "commonShader": { "file": "panelSeams.common.glsl" },
      "colorShader": { "file": "panelSeams.color.glsl" },
      "lightAttenuationShader": { "file": "panelSeams.attenuation.glsl" },
      "pomHeightShader": { "file": "panelSeams.height.glsl" },
      "pomNormalShader": { "file": "panelSeams.normal.glsl" }
    }
  }
}
