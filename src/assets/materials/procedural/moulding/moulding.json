{
  "$schema": "../../../library-material-schema.json",
  "material": {
    "type": "customShader",
    "props": {
      "color": "#b08b57",
      "roughness": 0.65,
      "metalness": 0,
      "envMapIntensity": 1
    },
    "options": {
      "useTriplanarMapping": false,
      "useGeneratedUVs": false,
      "pom": {
        "depth": 0.07,
        "steps": 8,
        "lodFadeStart": 12,
        "lodFadeRange": 30,
        "refinement": "binary",
        "refinementSteps": 3,
        "applyReliefNormal": true,
        "boundedSilhouette": true
      }
    },
    "shaders": {
      "commonShader": { "file": "moulding.common.glsl" },
      "colorShader": { "file": "moulding.color.glsl" },
      "roughnessShader": { "file": "moulding.roughness.glsl" },
      "lightAttenuationShader": { "file": "moulding.attenuation.glsl" },
      "pomHeightShader": { "file": "moulding.height.glsl" },
      "pomNormalShader": { "file": "moulding.normal.glsl" }
    }
  }
}
