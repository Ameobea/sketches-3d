{
  "$schema": "../../../library-material-schema.json",
  "material": {
    "type": "customShader",
    "props": {
      "color": "#30333a",
      "roughness": 0.65,
      "metalness": 0.05
    },
    "options": {
      "useTriplanarMapping": false,
      "useGeneratedUVs": false,
      "pom": {
        "tier": "projectedField",
        "hitType": "ChHit",
        "intersect": "safeStep",
        "minFeatureWidth": 0.05,
        "lateralDist": true,
        "depth": 0.16,
        "steps": 12,
        "lodFadeStart": 14,
        "lodFadeRange": 40,
        "boundedSilhouette": true,
        "refinement": "binary",
        "refinementSteps": 6,
        "applyReliefNormal": true
      }
    },
    "shaders": {
      "commonShader": { "file": "chevronStrips.common.glsl" },
      "colorShader": { "file": "chevronStrips.color.glsl" },
      "lightAttenuationShader": { "file": "chevronStrips.attenuation.glsl" },
      "pomHeightShader": { "file": "chevronStrips.height.glsl" },
      "pomNormalShader": { "file": "chevronStrips.normal.glsl" }
    }
  }
}
