set dotenv-load := true

copy-files:
  cp -r ./build/* ../wasmComp
  cp ./build2/*.wasm ../wasmComp
  cp ./build2/flight_recorder.wasm ../wasmComp
  cp -r ./geodesics/build/bin/* ../../../src/geodesics/

bindgen:
  wasm-bindgen ./target/wasm32-unknown-unknown/release/bridge2.wasm --target web --remove-producers-section --out-dir ./build
  wasm-bindgen ./target/wasm32-unknown-unknown/release/conduit_particles.wasm --target web --remove-producers-section --out-dir ./build
  wasm-bindgen ./target/wasm32-unknown-unknown/release/cave.wasm --target web --remove-producers-section --out-dir ./build
  wasm-bindgen ./target/wasm32-unknown-unknown/release/stone.wasm --target web --remove-producers-section --out-dir ./build
  wasm-bindgen ./target/wasm32-unknown-unknown/release/tessellation_sandbox.wasm --target web --remove-producers-section --out-dir ./build
  wasm-bindgen ./target/wasm32-unknown-unknown/release/basalt.wasm --target web --remove-producers-section --out-dir ./build
  wasm-bindgen ./target/wasm32-unknown-unknown/release/csg_sandbox.wasm --target web --remove-producers-section --out-dir ./build
  wasm-bindgen ./target/wasm32-unknown-unknown/release/geoscript_repl.wasm --target web --remove-producers-section --out-dir ./build
  wasm-bindgen ./target/wasm32-unknown-unknown/release/geoscript_analysis_wasm.wasm --target web --remove-producers-section --out-dir ./build

  cp ./target/wasm32-unknown-unknown/release/normal_map_gen.wasm ./build2
  cp ./target/wasm32-unknown-unknown/release/texture_crossfade.wasm ./build2
  cp ./target/wasm32-unknown-unknown/release/terrain.wasm ./build2
  cp ./target/wasm32-unknown-unknown/release/flight_recorder.wasm ./build2
  cp ./target/wasm32-unknown-unknown/release/sound_engine.wasm ./build2
  cp ./build2/*.wasm ../wasmComp

opt:
  #!/usr/bin/env -S parallel --shebang --ungroup --jobs 6
  ./optimize-wasm.sh ./build/bridge2_bg.wasm
  ./optimize-wasm.sh ./build/conduit_particles_bg.wasm
  ./optimize-wasm.sh ./build2/normal_map_gen.wasm
  ./optimize-wasm.sh ./build2/texture_crossfade.wasm
  ./optimize-wasm.sh ./build/cave_bg.wasm
  ./optimize-wasm.sh ./build2/terrain.wasm
  ./optimize-wasm.sh ./build/stone_bg.wasm
  ./optimize-wasm.sh ./geodesics/build/bin/geodesics.wasm
  ./optimize-wasm.sh ./build/tessellation_sandbox_bg.wasm
  ./optimize-wasm.sh ./build/basalt_bg.wasm
  ./optimize-wasm.sh ./build/csg_sandbox_bg.wasm
  ./optimize-wasm.sh ./build/geoscript_repl_bg.wasm
  ./optimize-wasm.sh ./build/geoscript_analysis_wasm_bg.wasm
  ./optimize-wasm.sh ./build2/flight_recorder.wasm
  ./optimize-wasm.sh ./build2/sound_engine.wasm

build:
  #!/bin/bash

  rm -rf ./build/*
  RUSTFLAGS="-Ctarget-feature=+simd128" cargo build --release --target wasm32-unknown-unknown --workspace

  just bindgen
  just build-geodesics

clean:
  rm -rf build/*
  rm -rf build2/*
  cd ./geodesics && just clean

build-geodesics:
  #!/bin/bash

  set -e

  cd ./geodesics
  if [ ! -f ./deps/geometry-central/README.md ]; then
    echo "fetching submodules"
    git submodule update --init --recursive
  fi

  if [ ! -f ./build/CMakeCache.txt ]; then
    echo "doing full build with CMake"
    just build-all
  else
    just build
  fi

  cd ..
  cp -r ./geodesics/build/bin/* ../../../src/geodesics/

debug:
  cargo build --target wasm32-unknown-unknown --workspace

  just bindgen
  just opt
  just copy-files

fmt:
  cargo fmt --all

# ---

build-cave:
  RUSTFLAGS="-Ctarget-feature=+simd128" cargo build --release --target wasm32-unknown-unknown --package cave
  wasm-bindgen ./target/wasm32-unknown-unknown/release/cave.wasm --target web --remove-producers-section --out-dir ./build
  cp ./build/cave* ../wasmComp

build-basalt:
  RUSTFLAGS="-Ctarget-feature=+simd128" cargo build --release --target wasm32-unknown-unknown --package basalt
  wasm-bindgen ./target/wasm32-unknown-unknown/release/basalt.wasm --target web --remove-producers-section --out-dir ./build
  cp ./build/basalt* ../wasmComp

build-csg-sandbox:
  cargo build --release --target wasm32-unknown-unknown --package csg_sandbox
  wasm-bindgen ./target/wasm32-unknown-unknown/release/csg_sandbox.wasm --target web --remove-producers-section --out-dir ./build
  # wasm-opt ./build/csg_sandbox_bg.wasm -g -O4 --enable-simd --enable-relaxed-simd --enable-nontrapping-float-to-int --precompute-propagate --strip-dwarf -c -o ./build/csg_sandbox_bg.wasm --enable-bulk-memory
  cp ./build/csg_sandbox* ../wasmComp

build-geoscript-repl:
  RUSTFLAGS="-C target-feature=+simd128" cargo build --profile dev-opt --target wasm32-unknown-unknown --package geoscript_repl
  wasm-bindgen ./target/wasm32-unknown-unknown/dev-opt/geoscript_repl.wasm --target web --remove-producers-section --out-dir ./build
  WASM_OPT_LEVEL=O2 ./optimize-wasm.sh ./build/geoscript_repl_bg.wasm
  cp ./build/geoscript_repl* ../wasmComp

build-geoscript-repl-release:
  RUSTFLAGS="-C target-feature=+simd128" cargo build --release --target wasm32-unknown-unknown --package geoscript_repl
  wasm-bindgen ./target/wasm32-unknown-unknown/release/geoscript_repl.wasm --target web --remove-producers-section --out-dir ./build
  ./optimize-wasm.sh ./build/geoscript_repl_bg.wasm
  cp ./build/geoscript_repl* ../wasmComp

build-geoscript-analysis:
  RUSTFLAGS="-C target-feature=+simd128" cargo build --profile dev-opt --target wasm32-unknown-unknown --package geoscript_analysis_wasm
  wasm-bindgen ./target/wasm32-unknown-unknown/dev-opt/geoscript_analysis_wasm.wasm --target web --remove-producers-section --out-dir ./build
  WASM_OPT_LEVEL=O2 ./optimize-wasm.sh ./build/geoscript_analysis_wasm_bg.wasm
  cp ./build/geoscript_analysis_wasm* ../wasmComp

build-geoscript-analysis-release:
  RUSTFLAGS="-C target-feature=+simd128" cargo build --release --target wasm32-unknown-unknown --package geoscript_analysis_wasm
  wasm-bindgen ./target/wasm32-unknown-unknown/release/geoscript_analysis_wasm.wasm --target web --remove-producers-section --out-dir ./build
  ./optimize-wasm.sh ./build/geoscript_analysis_wasm_bg.wasm
  cp ./build/geoscript_analysis_wasm* ../wasmComp

build-geoscript:
  #!/bin/bash
  set -e
  RUSTFLAGS="-C target-feature=+simd128" cargo build --profile dev-opt --target wasm32-unknown-unknown --package geoscript_repl --package geoscript_analysis_wasm
  export WASM_OPT_LEVEL=O2
  (
    wasm-bindgen ./target/wasm32-unknown-unknown/dev-opt/geoscript_repl.wasm --target web --remove-producers-section --out-dir ./build
    ./optimize-wasm.sh ./build/geoscript_repl_bg.wasm
    cp ./build/geoscript_repl* ../wasmComp
  ) & repl=$!
  (
    wasm-bindgen ./target/wasm32-unknown-unknown/dev-opt/geoscript_analysis_wasm.wasm --target web --remove-producers-section --out-dir ./build
    ./optimize-wasm.sh ./build/geoscript_analysis_wasm_bg.wasm
    cp ./build/geoscript_analysis_wasm* ../wasmComp
  ) & analysis=$!
  wait $repl && wait $analysis

build-flight-recorder:
  RUSTFLAGS="-Ctarget-feature=+simd128" cargo build --release --target wasm32-unknown-unknown --package flight_recorder
  cp ./target/wasm32-unknown-unknown/release/flight_recorder.wasm ./build2
  ./optimize-wasm.sh ./build2/flight_recorder.wasm
  cp ./build2/flight_recorder.wasm ../wasmComp

build-sound-engine:
  RUSTFLAGS="-Ctarget-feature=+simd128" cargo build --release --target wasm32-unknown-unknown --package sound_engine
  cp ./target/wasm32-unknown-unknown/release/sound_engine.wasm ./build2
  ./optimize-wasm.sh ./build2/sound_engine.wasm
  cp ./build2/sound_engine.wasm ../wasmComp
