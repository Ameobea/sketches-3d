{
  "typescript.tsdk": "node_modules/typescript/lib",
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "src/viz/wasm/geodesics/deps/**": true
  },
  "files.associations": {
    "*.jsx": "javascript",
    "*.hbs": "html",
    "deque": "cpp",
    "list": "cpp",
    "vector": "cpp",
    "ranges": "cpp"
  },
  "eslint.enable": false,
  "prettier.enable": false,
  "oxc.enable": true,
  "python-envs.defaultEnvManager": "ms-python.python:system",
  "python-envs.pythonProjects": [],
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[svelte]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  }
}
